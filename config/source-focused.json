{
  "profile": {
    "name": "source-focused",
    "description": "Focuses on events from specific sources or services"
  },
  "input_settings": {
    "log_timestamp_format": "syslog",
    "file_encoding": "utf-8"
  },
  "output_settings": {
    "output_file_path": "output/source-focused.txt",
    "write_run_summary": true,
    "write_statistics": true,
    "output_verbosity_level": "normal"
  },
  "time_range": {
      "enabled": false,
      "timezone": "UTC",
      "start_time": null,
      "end_time": null
  },
  "filtering": {
    "rules": [
      {
        "rule_name": "service_activity",
        "match_log_levels": ["INFO", "WARN", "ERROR"],
        "match_sources": ["validator-controller", "validator-reader"],
        "match_logger_name_contains": null,
        "match_message_contains": null,
        "include_context_before_seconds": 5,
        "include_context_after_seconds": 5
      }
    ],
    "exclude_log_levels": ["DEBUG"],
    "exclude_sources": [],
    "exclude_messages_containing": []
  },
  "statistics": {
    "enable_statistics": true,
    "count_entries_by_level": true,
    "count_entries_by_rule": true,
    "count_entries_by_source": true,
    "detect_repeated_messages": true,
    "top_repeated_message_limit": 10
  }
}