{
  "profile": {
    "name": "error-focused",
    "description": "Highlights error-level events with statistics and minimal noise"
  },
  "input_settings": {
    "log_timestamp_format": "syslog",
    "file_encoding": "utf-8"
  },
  "output_settings": {
    "output_file_path": "output/error-focused.txt",
    "write_run_summary": true,
    "write_statistics": true,
    "output_verbosity_level": "normal"
  },
  "filtering": {
    "rules": [
      {
        "rule_name": "error_events",
        "match_log_levels": ["ERROR"],
        "match_sources": null,
        "match_logger_name_contains": null,
        "match_message_contains": null,
        "include_context_before_seconds": 10,
        "include_context_after_seconds": 10
      }
    ],
    "exclude_log_levels": ["DEBUG", "TRACE"],
    "exclude_sources": [],
    "exclude_messages_containing": []
  },
  "statistics": {
    "enable_statistics": true,
    "count_entries_by_level": true,
    "count_entries_by_rule": true,
    "count_entries_by_source": true,
    "detect_repeated_messages": true,
    "top_repeated_message_limit": 10
  }
}