{
  "profile": {
    "name": "log-level-focused",
    "description": "Highlights events based on lof level (INFO, WARN, DEBUG, ERROR) with statistics and minimal noise"
  },
  "input_settings": {
    "log_timestamp_format": "syslog",
    "file_encoding": "utf-8"
  },
  "output_settings": {
    "output_file_path": "output/log-level-focused.txt",
    "strip_common_log_prefix": true
  },
  "time_range": {
    "enabled": false,
    "timezone": "UTC",
    "start_time": "10:15:00",
    "end_time": null
  },
  "filtering": {
    "rules": [
      {
        "rule_name": "log_level_match",
        "match_log_levels": ["INFO"],
        "match_sources": null,
        "match_logger_name_contains": null,
        "match_message_contains": null,
        "include_context_before_seconds": 1,
        "include_context_after_seconds": 1
      }
    ]
  }
}