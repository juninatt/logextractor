{
  "profile": {
    "name": "noise-reduction",
    "description": "Reduces log noise by excluding common low-value events"
  },
  "input_settings": {
    "log_timestamp_format": "syslog",
    "file_encoding": "utf-8"
  },
  "output_settings": {
    "output_file_path": "output/noise-reduction.txt",
    "write_run_summary": true,
    "write_statistics": true,
    "output_verbosity_level": "minimal"
  },
  "filtering": {
    "rules": [
      {
        "rule_name": "important_events",
        "match_log_levels": ["WARN", "ERROR"],
        "match_sources": null,
        "match_logger_name_contains": null,
        "match_message_contains": null,
        "include_context_before_seconds": 5,
        "include_context_after_seconds": 5
      }
    ],
    "exclude_log_levels": ["DEBUG", "TRACE"],
    "exclude_sources": ["systemd", "systemd-journald"],
    "exclude_messages_containing": ["heartbeat", "health check", "polling"]
  },
  "statistics": {
    "enable_statistics": true,
    "count_entries_by_level": true,
    "count_entries_by_rule": true,
    "count_entries_by_source": true,
    "detect_repeated_messages": true,
    "top_repeated_message_limit": 10
  }
}