{
  "input": {
    "timestamp_format": "syslog",
    "encoding": "utf-8"
  },
  "output": {
    "file_path": "output/filtered_log.txt",
    "include_summary": true,
    "include_statistics": true,
    "verbosity": "normal"
  },
  "filters": {
    "rules": [
      {
        "name": "error_events",
        "levels": ["ERROR"],
        "processes": ["app-service"],
        "logger_contains_any": ["com.example.service"],
        "message_contains_any": ["Failed"],
        "context_before_seconds": 0,
        "context_after_seconds": 0
      }
    ],
    "global_exclude_levels": [],
    "global_exclude_processes": [],
    "global_exclude_message_contains": []
  },
  "statistics": {
    "enabled": true,
    "count_by_level": true,
    "count_by_rule": true,
    "count_by_process": true,
    "detect_repetitive_messages": true,
    "top_repetitive_message_limit": 10
  }
}